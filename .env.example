# ─────────────────────────────────────────────────────────────
# Iberfuego — variables de entorno (copiar a .env.local)
# Ninguna clave es obligatoria para arrancar en modo mock.
# ─────────────────────────────────────────────────────────────

# NASA FIRMS — MAP_KEY gratuito: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Límite: 5000 transacciones / 10 min. El backend cachea para no agotarlo.
FIRMS_MAP_KEY=

# fogos.pt — la API está endureciendo el acceso (registro en https://fogos.pt/pt/api)
FOGOS_API_TOKEN=

# Web Push (VAPID) — generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contacto@iberfuego.com

# URL pública (para OG images y enlaces /f/{slug})
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Estilo base de teselas (OpenFreeMap por defecto, sin API key)
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Fuente de datos: "mock" (por defecto) o "live"
NEXT_PUBLIC_DATA_MODE=mock
