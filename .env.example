# ─────────────────────────────────────────────────────────────
# Incendib — variables de entorno (copiar a .env.local)
# Ninguna clave es obligatoria para arrancar en modo mock.
# ─────────────────────────────────────────────────────────────

# NASA FIRMS — MAP_KEY gratuito: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Límite: 5000 transacciones / 10 min. El backend cachea para no agotarlo.
FIRMS_MAP_KEY=

# fogos.pt — la API está endureciendo el acceso (registro en https://fogos.pt/pt/api)
FOGOS_API_TOKEN=

# Copernicus Data Space Ecosystem (Sentinel Hub) — OPCIONAL, gratuito.
# Si se definen, la imagen de "Historia" al compartir un incendio usa una escena
# Sentinel-2 reciente en FALSO COLOR (la cicatriz de quemado se ve en los píxeles).
# Sin ellas, se usa el mosaico Sentinel-2 cloudless de EOX como respaldo keyless.
# Crear un cliente OAuth en https://dataspace.copernicus.eu → Sentinel Hub →
# "OAuth clients". Plan gratuito (Copernicus General): 10 000 unidades de
# proceso/mes (de sobra para imágenes de compartir puntuales).
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# Web Push (VAPID) — generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contacto@incendib.es

# URL pública (para OG images y enlaces /f/{slug}). En producción: https://incendib.es
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Estilo base de teselas oscuro (OpenFreeMap, sin API key). Anula el tema oscuro.
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/dark

# Fuente de datos: "mock" (por defecto) o "live"
NEXT_PUBLIC_DATA_MODE=mock

# Secreto para proteger los endpoints de tarea programada (/api/push/cron y
# /api/boletin/generar). ⚠️ RECOMENDADO EN PRODUCCIÓN: sin él, ambos endpoints
# quedan abiertos (cualquiera podría disparar el envío de alertas o forzar la
# generación del boletín). Defínelo en Vercel (Production) y, para la GitHub
# Action del boletín, añade el mismo valor como secreto del repo. Vercel Cron
# adjunta automáticamente "Authorization: Bearer $CRON_SECRET" si la variable
# existe. Genera uno con: openssl rand -hex 32
CRON_SECRET=

# Almacén de suscripciones Web Push (Upstash Redis REST). Sin estas variables las
# alertas automáticas quedan inactivas (sin romper nada).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
